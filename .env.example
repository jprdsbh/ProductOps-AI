# ─── DATABASE ───────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/release_notes"

# ─── JWT ────────────────────────────────────────────────
JWT_SECRET="replace-with-a-long-random-secret-min-32-chars"
JWT_EXPIRES_IN="7d"

# ─── ANTHROPIC ──────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─── CLICKUP ────────────────────────────────────────────
CLICKUP_WEBHOOK_SECRET="your-clickup-webhook-secret"
# Status name that triggers release note generation (case-insensitive)
CLICKUP_TRIGGER_STATUS="done"

# ─── ADMIN ──────────────────────────────────────────────
# Used by seed script to create the first admin user
ADMIN_EMAIL="admin@tpay.com.br"
ADMIN_PASSWORD="change-me-on-first-login"

# ─── CORS / URLs ────────────────────────────────────────
API_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"
