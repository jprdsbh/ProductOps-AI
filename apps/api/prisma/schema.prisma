generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ReleaseNoteStatus {
  DRAFT
  PENDING_APPROVAL
  PUBLISHED
  ARCHIVED
}

model ReleaseNote {
  id             String            @id @default(cuid())
  clickupTaskId  String            @unique
  clickupTaskUrl String?
  customId       String?
  rawTitle       String
  rawDescription String            @db.Text
  aiGenerated    String            @db.Text
  finalText      String?           @db.Text
  status         ReleaseNoteStatus @default(DRAFT)
  category       String?
  version        String?
  imageUrl         String?           @db.Text
  suggestedCapture String?           @db.Text
  suggestedRoute   String?
  assigneeName     String?
  sprintName       String?
  epicName         String?
  releasedAt     DateTime?         // data em que a task foi para "closed" no ClickUp (modificação no ar)
  publishedAt    DateTime?         // data em que o changelog foi aceito/aprovado no admin
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([status])
}

model ProcessedEvent {
  id        String   @id
  createdAt DateTime @default(now())
}

model Subscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  active      Boolean  @default(true)
  unsubToken  String   @unique @default(cuid())
  createdAt   DateTime @default(now())
}

// Cache persistente de geração de IA
// Evita chamar a API para conteúdo idêntico já processado antes
model AiCache {
  id               String   @id @default(cuid())
  inputHash        String   @unique  // SHA-256 de title+description+category+version
  text             String   @db.Text
  suggestedCapture String   @db.Text
  suggestedRoute   String
  model            String   @default("claude-sonnet-4-6")
  usageCount       Int      @default(1)
  createdAt        DateTime @default(now())
  lastUsedAt       DateTime @default(now())

  @@index([inputHash])
}

// ─── Base de Conhecimento compartilhada ──────────────────────────────────────
// Sistema de registro único onde TBot e o Release-Agent aprendem juntos:
// - TBot grava rotas reais descobertas + navegação que funcionou (category 'route'/'navigation')
// - Release-Agent grava/consulta o mapeamento feature→rota pra sugerir capturas reais
// Quanto mais o sistema roda, mais preciso fica (menos alucinação de URL).
model KnowledgeEntry {
  id         String   @id @default(cuid())
  category   String   // 'route' | 'navigation' | 'test_learning' | 'glossary'
  key        String   // chave normalizada (ex.: '/sales' ou slug da feature)
  title      String?
  content    String   @db.Text   // resumo legível do aprendizado
  data       Json?    // payload estruturado opcional (passos, seletores, insights de API)
  source     String   // 'tbot' | 'release-agent' | 'manual'
  confidence Float    @default(0.5)
  hitCount   Int      @default(1)
  lastUsedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([category, key])
  @@index([category])
}

// Batch de geração via Anthropic Message Batches API (50% mais barato, async).
// Cada batch agrupa várias notas; ficamos com o batchId pra consultar quando
// a Anthropic terminar (até 24h, normalmente minutos) e aplicar os resultados.
model AiBatch {
  id           String   @id @default(cuid())
  batchId      String   @unique // anthropic batch_id (msgbatch_...)
  status       String   // submitted | in_progress | ended | canceled | failed
  noteIds      Json     // array de ReleaseNote.id incluídos no batch (e seu custom_id no request)
  total        Int      // quantidade de requests no batch
  succeeded    Int      @default(0)
  errored      Int      @default(0)
  model        String
  createdAt    DateTime @default(now())
  endedAt      DateTime?
  processedAt  DateTime?

  @@index([status])
}

// Estatísticas de uso da API de IA
model AiUsageStat {
  id         String   @id @default(cuid())
  date       String   // YYYY-MM-DD
  apiCalls   Int      @default(0)
  cacheHits  Int      @default(0)
  tokensSaved Int     @default(0) // tokens economizados via cache
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([date])
}
