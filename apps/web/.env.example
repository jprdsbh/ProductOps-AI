# URL da API (apontar pra prod no Railway ou local)
API_URL=http://localhost:3002

# URL do TBot (server-side: o admin proxia chamadas pra cá com X-TBot-Token).
# - Local: http://localhost:8000
# - Prod:  https://tbot.tpay.com.br  (Cloudflare Tunnel apontando pro seu PC)
TBOT_URL=http://localhost:8000

# Token compartilhado com o TBot (mesmo valor que está em apps/tbot/.env).
# NUNCA prefixe com NEXT_PUBLIC_ — deve ficar só no server-side.
TBOT_TOKEN=
